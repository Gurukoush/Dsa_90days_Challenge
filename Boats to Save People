class Solution:
    def numRescueBoats(self, people: List[int], limit: int) -> int:
        people.sort()
        n = len(people) #2
        result = 0
        i = 0
        j = n-1

        while i<=j:
            remain = limit - people[j]
            # 0
            # 1

            j-=1
            result +=1

            if i<=j and remain>=people[i]:
                i+=1
        return result
