class Solution:
    def checkInclusion(self, s1: str, s2: str) -> bool:
        s1_permu = ("".join(p) for p in permutations(s1))

        s1_len = len(s1)
        s2_len = len(s2)

        for i in range(s2_len-s1_len+1):
            if s2[i:i+s1_len] in permutations:
                return True
        return False
