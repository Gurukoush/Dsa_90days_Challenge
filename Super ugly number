class Solution:
    def nthSuperUglyNumber(self, n: int, primes: List[int]) -> int:
        k = len(primes)
        dp = [1] * n
        pointers = [0] * k

        for i in range(1, n):
            candidates = [primes[j] * dp[pointers[j]] for j in range(k)]
            next_ugly = min(candidates)
            dp[i] = next_ugly

            for j in range(k):
                if candidates[j] == next_ugly:
                    pointers[j] += 1

        return dp[-1]
