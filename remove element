# optimal approach
class Solution:
    def removeElement(self, nums: List[int], val: int) -> int:

        i = 0
        for j in range(len(nums)):
            if nums[j]!=val:
                nums[i] = nums[j]
                i+=1
        return i


# better approach

class Solution:
    def removeElement(self, arr, val):

        i = 0
        j = 0
        while i<len(arr):
            if arr[i]!=val:
                arr[j]=arr[i]
                j+=1
            i+=1
        return j


