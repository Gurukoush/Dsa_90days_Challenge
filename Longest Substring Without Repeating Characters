class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        n = len(s)
        max_len = 0
        for i in range(0,n):
            seen = []
            for j in range(i,n):
                if s[j] in seen:
                    break
                seen.append(s[j])
                length = j-i+1

                max_len = max(max_len,length)
        return max_len



class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        char = set()
        start = 0
        n = len(s)
        max_len = 0
        for end in range(n):
            while s[end] in char:
                char.remove(s[start])
                start+=1
            
            char.add(s[end])




            lenght = end - start+1
            max_len = max(max_len,lenght)

        return max_len
        
