
class Solution:
    def getLucky(self, s: str, k: int) -> int:
        # Step 1: Convert and sum digits directly
        num = 0
        for ch in s:
            val = ord(ch) - ord('a') + 1
            for digit in str(val):
                num += int(digit)

        # Step 2: Repeat k-1 times
        for _ in range(k - 1):
            temp = 0
            for digit in str(num):
                temp += int(digit)
            num = temp

        return num
