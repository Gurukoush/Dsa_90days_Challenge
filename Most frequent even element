class Solution:
    def mostFrequentEven(self, nums):
        n = len(nums)
        max_freq = 0
        result = -1

        for i in range(n):
            if nums[i] % 2 == 0:
                count = 0
                for j in range(n):
                    if nums[i] == nums[j]:
                        count += 1

                if count > max_freq or (count == max_freq and nums[i] < result):
                    max_freq = count
                    result = nums[i]

        return result
