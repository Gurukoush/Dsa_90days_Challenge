class Solution:
    def numberOfUniqueGoodSubsequences(self, s: str) -> int:
        MOD = 10**9 + 7
        
        end0 = 0
        end1 = 0
        has0 = 0
        
        for ch in s:
            if ch == '1':
                end1 = (end0 + end1 + 1) % MOD
            else:
                end0 = (end0 + end1) % MOD
                has0 = 1
        
        return (end0 + end1 + has0) % MOD
